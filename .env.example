# ── الزامی ───────────────────────────────────────────────────────────────
# توکن ربات تلگرام (از @BotFather بگیرید)
TELEGRAM_BOT_TOKEN=

# این دو مقدار فقط برای اجرای سرور لوکال Telegram Bot API لازم‌اند
# (از https://my.telegram.org بگیرید)
TELEGRAM_API_ID=
TELEGRAM_API_HASH=

# ── اختیاری ──────────────────────────────────────────────────────────────
# آدرس سرور Bot API (پیش‌فرض: سرور لوکال داکر)
TELEGRAM_BOT_API_URL=http://localhost:8081

# مسیر ذخیره فایل‌های دانلودشده توسط سرور لوکال
LOCAL_FILES_DIR=/tmp/telegram-bot-api

# ── کلیدهای API سرویس‌های آپلود ─────────────────────────────────────────
# پیکسل‌درین: بدون این مقدار هم کار می‌کند (آپلود مهمان)، اما با کلید
# فایل‌ها به حساب شما متصل می‌شوند و محدودیت حجم بیشتری دارید.
PIXELDRAIN_API_KEY=

# گوفایل (GoFile.io): بدون این مقدار هم کار می‌کند (آپلود مهمان).
# اگر می‌خواهید فایل‌ها به حساب گوفایل‌تان متصل شوند، توکن حساب را اینجا بگذارید.
GOFILE_API_TOKEN=

# storage.to: هیچ API Key یا حسابی لازم ندارد؛ به همین دلیل متغیری
# برایش تعریف نشده است.
